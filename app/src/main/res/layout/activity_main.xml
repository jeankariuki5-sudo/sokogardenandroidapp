<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#FFD88A"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✳️ Soko Garden ✳️"
        android:textSize="45sp"
        android:fontFamily="cursive"
        android:background="@drawable/shape"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="@color/black"/>

<!--    Below is a linear layout that aligns content horizontaly-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 Sign Up"
            android:textSize="30sp"
            android:padding="10dp"
            android:fontFamily="cursive"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="8dp"
            android:textColor="#E1CDD8"
            android:backgroundTint="#18421B"
            android:id="@+id/signupBtn" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👮 Sign In"
            android:textSize="30sp"
            android:padding="10dp"
            android:fontFamily="cursive"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="8dp"
            android:textColor="#E1CDD8"
            android:backgroundTint="#18421B"
            android:id="@+id/signinBtn" />


    </LinearLayout>

<!--    Below is out progress bar-->
    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/progressbar"/>

<!--    Below is our recycler view-->
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:listitem="@layout/single_item"
        android:id="@+id/recyclerview"/>


</LinearLayout>
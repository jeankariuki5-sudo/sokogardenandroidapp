<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:background="#6D421E"
    tools:context=".SignIn">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="cursive"
        android:text="✳️ Sign In ✳️"
        android:textSize="45sp"
        android:background="@drawable/shape"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="@color/black"
        android:layout_marginBottom="60dp"/>

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:padding="10dp"
        android:paddingTop="50dp"
        android:layout_marginTop="50dp"
        android:layout_margin="10dp">

<!--        Below is a linear layout that shall align content vertivally-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#FFD88A">

<!--            Below is the email edit text-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="✉️ Enter Email Address"
                android:inputType="textEmailAddress"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:id="@+id/email"
                android:textColor="@color/black"
                android:layout_margin="8dp"
                android:background="#B3F69B"
                android:padding="11dp"/>


            <!--            Below is the password edit text-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter Your Password"
                android:inputType="textPassword"
                android:textSize="22sp"
                android:textColorHint="#000"
                android:id="@+id/password"
                android:textColor="@color/black"
                android:layout_margin="8dp"
                android:background="#B3F69B"
                android:padding="11dp"/>

<!--            Below is the signin button with it's properties-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👮 Sign In"
                android:textSize="30sp"
                android:padding="10dp"
                android:fontFamily="cursive"
                android:layout_marginTop="30dp"
                android:textColor="#E1CDD8"
                android:backgroundTint="#18421B"
                android:id="@+id/signinBtn" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signup_text"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#000"
                android:id="@+id/signuptxt"/>


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
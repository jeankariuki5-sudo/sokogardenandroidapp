<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFD88A"
    tools:context=".About">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="About Us"
        android:textStyle="bold"
        android:textSize="42sp"
        android:textColor="#000"
        android:textAlignment="center" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        app:cardElevation="15dp"
        android:padding="10dp"
        app:cardCornerRadius="15dp"
        android:background="#FFD88A">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_margin="10dp"
            android:background="#6D421E"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/aboutTxt"
                android:text="Welcome to our Ecommerce application, a simple user friendly platform designed to make online shopping easy and accessible for everyone. Users can quickly create acconts, securely log in and browse a wide range of products with detailed description and the product photos. Our seemly checkout process allows customers to pay conviently by use of Mpesa. We are have and look forward working and doing bussiness with you."
                android:textSize="22sp"
                android:textColor="#fff"
                android:textAlignment="center"
                android:layout_marginTop="10dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:id="@+id/btnListen"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:text="🎙️Know Us"
                android:textSize="23sp"
                android:backgroundTint="#19451C" />

        </LinearLayout>


    </androidx.cardview.widget.CardView>



</LinearLayout>
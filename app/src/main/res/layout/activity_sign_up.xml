<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#6D421E"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SignUp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="cursive"
        android:text="✳️ Sign Up ✳️"
        android:textSize="45sp"
        android:background="@drawable/shape"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="@color/black"
        android:layout_marginBottom="30dp"/>
    
    
<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FFD88A">

<!--            Below is the edit text for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Enter Your User Name"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#B3F69B"
                android:padding="11dp"/>


            <!--            Below is the edit text for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="✉️ Enter Your Email"
                android:inputType="textEmailAddress"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/email"
                android:layout_margin="8dp"
                android:background="#B3F69B"
                android:padding="11dp"/>


            <!--            Below is the edit text for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter Your Password"
                android:textColorHint="#000"
                android:inputType="textPassword"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/password"
                android:layout_margin="8dp"
                android:background="#B3F69B"
                android:padding="11dp"/>


            <!--            Below is the edit text for phone-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞 Enter Your Phone Number"
                android:inputType="phone"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:id="@+id/phone"
                android:layout_margin="8dp"
                android:background="#B3F69B"
                android:padding="11dp"/>

<!--            Below is the signup button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Sign Up"
                android:textSize="30sp"
                android:padding="10dp"
                android:fontFamily="cursive"
                android:layout_marginTop="25dp"
                android:textColor="#E1CDD8"
                android:backgroundTint="#18421B"
                android:id="@+id/signupBtn" />


            <TextView

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already Have an Account? Signin"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="@color/black"
                android:id="@+id/signintxt" />




        </LinearLayout>

    </androidx.cardview.widget.CardView>


</LinearLayout>